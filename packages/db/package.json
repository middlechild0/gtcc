{
  "name": "@visyx/db",
  "private": true,
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:verify": "bun run src/verify-schema.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "bun test --pass-with-no-tests",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    "./client": "./src/client.ts",
    "./job-client": "./src/job-client.ts",
    "./worker-client": "./src/worker-client.ts",
    "./queries": "./src/queries/index.ts",
    "./errors": "./src/errors.ts",
    "./schema": "./src/schema.ts",
    "./permissions": "./src/permissions.ts",
    "./utils/search-query": "./src/utils/search-query.ts",
    "./utils/health": "./src/utils/health.ts",
    "./utils/log-activity": "./src/utils/log-activity.ts"
  },
  "dependencies": {
    "@date-fns/tz": "catalog:",
    "@date-fns/utc": "^2.1.1",
    "@sindresorhus/slugify": "catalog:",
    "@types/pg": "^8.15.6",
    "@visyx/cache": "workspace:*",
    "@visyx/encryption": "workspace:*",
    "@visyx/logger": "workspace:*",
    "@visyx/utils": "workspace:*",
    "camelcase-keys": "catalog:",
    "drizzle-orm": "^0.45.0",
    "nanoid": "catalog:",
    "pg": "^8.16.3",
    "snakecase-keys": "^9.0.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.8"
  }
}
